#!/usr/bin/env bash

root=$(dirname $0)/..
version=$1
if [[ -z $version ]]; then
  echo "Usage: $(basename $0) NEW_VERSION"
  exit 1
fi

npm version $version --no-git-tag-version --allow-same-version
npm version $version --workspaces --no-git-tag-version --allow-same-version

if [[ "$OSTYPE" = darwin* ]]; then
  sedreplace=("sed" "-Ei" '')
else
  sedreplace=("sed" "-Ei")
fi

for template in template.yml examples/sam/customization/template.yaml examples/cloudformation/custom_hostname.yml; do
  "${sedreplace[@]}" "s/SemanticVersion: .+/SemanticVersion: $version/" $root/$template
done
"${sedreplace[@]}" "s/  serverless_iiif_app_version(\s*)=.+/  serverless_iiif_app_version\1= \"$version\"/" $root/extras/terraform/main.tf
