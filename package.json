{
  "name": "serverless-iiif",
  "version": "7.0.1",
  "description": "Lambda wrapper for iiif-processor",
  "author": "Michael B. Klein",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.34.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "aws-sdk-client-mock": "3.0.0",
    "aws-sdk-client-mock-jest": "3.0.0",
    "concat-stream": "^2.0.0",
    "concurrently": "^9.2.1",
    "coveralls": "^3.1.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-typescript": "^3.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^16.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "nodemon": "^3.1.11",
    "sharp": "^0.34.3",
    "ts-jest": "^29.4.1",
    "tsup": "^8.5.1",
    "yaml": "^2.3.1"
  },
  "scripts": {
    "clean": "bin/build clean",
    "lint": "eslint --ext .ts src tests",
    "lint-fix": "eslint --fix --ext .ts src tests",
    "test": "node scripts/test.js --env=jsdom",
    "test-coverage": "node scripts/test.js --env=jsdom --coverage",
    "build": "bin/build build",
    "test-build": "bin/build test-build",
    "deploy": "bin/build deploy",
    "deploy-guided": "bin/build deploy-guided",
    "delete-stack": "bin/build delete-stack",
    "dev": "bin/build dev",
    "package": "bin/build package",
    "publish": "bin/build publish",
    "serve": "concurrently --names build,server --colors blue,green \"npx tsup --watch ./src -d ./dist ./src/index.ts\" \"sam local start-api -t template.local.yml --host 0.0.0.0 --env-vars $PWD/env.json --log-file serverless-iiif.log --warm-containers EAGER\"",
    "create-metadata": "tsx src/utils/create-metadata.ts",
    "create-tiled-tiff": "tsx src/utils/create-tiled-tiff.ts"
  },
  "workspaces": [
    "src",
    "docs"
  ],
  "dependencies": {
    "iiif-processor": "^8.0.0"
  }
}
